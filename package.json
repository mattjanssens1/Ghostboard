{
 "name": "ghostboard",
 "private": true,
 "version": "0.0.0",
 "workspaces": [
  "apps/*",
  "packages/*"
 ],
 "engines": {
  "node": ">=20.0.0"
 },
 "scripts": {
  "dev": "npm run dev --workspace @ghostboard/web",
  "build": "npm run build --workspace @ghostboard/web",
  "typecheck": "npm run typecheck --workspaces --if-present"
 }
}
